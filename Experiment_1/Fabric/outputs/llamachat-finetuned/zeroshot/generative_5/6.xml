<Plan ID="MainTree">
        <Sequence>
            <!-- Check each waypoint and move the robot if it cannot reach the current one -->
            <Fallback>
                <Sequence>
                    <CheckBlackboard input="move_goal" ID="MoveGoalCheck" />
                    <Sequence>
                        <Nav2AroundGoal goal="move_goal" ID="Nav2AroundGoal" />
                    </Sequence>
                </Sequence>
                <Sequence>
                    <CheckBlackboard input="move_goal" ID="MoveGoalCheck" />
                    <Sequence>
                        <Nav2Move goal="-3.0,-1.0" ID="Nav2Move" />
                    </Sequence>
                </Sequence>
            </Fallback>
            <Sequence>
                <CheckBlackboard input="move_goal" ID="MoveGoalCheck" />
                <Sequence>
                    <Nav2Move goal="0.0,-2.0" ID="Nav2Move" />
                </Sequence>
            </Sequence>
            <Sequence>
                <CheckBlackboard input="move_goal" ID="MoveGoalCheck" />
                <Sequence>
                    <Nav2Move goal="1.0,3.0" ID="Nav2Move" />
                </Sequence>
            </Sequence>
            <Sequence>
                <CheckBlackboard input="move_goal" ID="MoveGoalCheck" />
                <Sequence>
                    <Nav2Move goal="-2.0,0.0" ID="Nav2Move" />
                </Sequence>
            </Sequence>
        </Sequence>
    </Plan>