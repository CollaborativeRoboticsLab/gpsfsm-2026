<Plan ID="MainTree">
        <Sequence>
            <!-- Test (2.0, -0.5) first -->
            <Repeat num_cycles="1">
                <Sequence>
                    <CheckBlackboard input="2.0" ID="CheckBlackboard"/>
                    <CheckBlackboard input="-0.5" ID="CheckBlackboard"/>
                    <Nav2AroundPos position="2.0;-0.5" />
                </Sequence>
            </Repeat>
            <!-- Test (1.0, 3.0) next -->
            <Repeat num_cycles="1">
                <Sequence>
                    <CheckBlackboard input="1.0" ID="CheckBlackboard"/>
                    <CheckBlackboard input="3.0" ID="CheckBlackboard"/>
                    <Nav2AroundPos position="1.0;3.0" />
                </Sequence>
            </Repeat>
            <!-- Test (-3.0, -1.0) next -->
            <Repeat num_cycles="1">
                <Sequence>
                    <CheckBlackboard input="-3.0" ID="CheckBlackboard"/>
                    <CheckBlackboard input="-1.0" ID="CheckBlackboard"/>
                    <Nav2AroundPos position="-3.0;-1.0" />
                </Sequence>
            </Repeat>
            <!-- Test (0.0, -2.0) last -->
            <Repeat num_cycles="1">
                <Sequence>
                    <CheckBlackboard input="0.0" ID="CheckBlackboard"/>
                    <CheckBlackboard input="-2.0" ID="CheckBlackboard"/>
                    <Nav2AroundPos position="0.0;-2.0" />
                </Sequence>
            </Repeat>
        </Sequence>
    </Plan>