        <MoveTo location="StationA"/>
        <MoveTo location="StationB"/>
      </Fallback>
      <Fallback name="VisitStationE_or_B">
        <MoveTo location="StationE"/>
        <MoveTo location="StationB"/>
      </Fallback>
      <Fallback name="VisitStationF_or_C">
        <MoveTo location="StationF"/>
        <MoveTo location="StationC"/>
      </Fallback>
      <Fallback name="VisitStationD_or_C">
        <MoveTo location="StationD"/>
        <MoveTo location="StationC"/>
      </Fallback>
    </Sequence>
  </BehaviorTree>
</root>