<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationF, StationD in sequence -->
            <Fallback>
                <Sequence>
                    <Sequence>
                        <SubTree ID="VisitStations" />
                    </Sequence>
                </Sequence>
                <Sequence>
                    <SubTree ID="VisitStations" />
                </Sequence>
                <Sequence>
                    <SubTree ID="VisitStations" />
                </Sequence>
                <SubTree ID="VisitStations" />
            </Fallback>
            <SubTree ID="VisitStations" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="VisitStations">
        <Fallback>
            <Action ID="MoveTo" goal="StationA" />
            <Action ID="MoveTo" goal="StationE" />
            <Action ID="MoveTo" goal="StationF" />
            <Action ID="MoveTo" goal="StationD" />
            <Action ID="MoveTo" goal="StationC" />
        </Fallback>
    </BehaviorTree>
</root>