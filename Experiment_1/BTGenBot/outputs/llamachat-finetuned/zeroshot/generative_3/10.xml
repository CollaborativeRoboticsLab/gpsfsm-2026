<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
           ; Visit Stations in sequence
            <SubTree ID="StationA" />
            <SubTree ID="StationE" fallback="MoveTo StationB" />
            <SubTree ID="StationC" />
            <SubTree ID="StationD" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationA">
        <Sequence>
            <MoveTo goal="1.1;2.1" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationB">
        <ForceSuccess>
            <Sequence>
                <MoveTo goal="2.0;3.1" />
            </Sequence>
        </ForceSuccess>
    </BehaviorTree>

    <BehaviorTree ID="StationC">
        <Sequence>
            <MoveTo goal="3.1;4.1" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationD">
        <Sequence>
            <MoveTo goal="4.0;5.1" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationE">
        <Fallback>
            <Sequence>
                <MoveTo goal="1.0;2.2" />
            </Sequence>
            <Sequence>
                <MoveTo goal="2.0;3.1" />
            </Sequence>
        </Fallback>
    </BehaviorTree>

    <BehaviorTree ID="MoveTo">
        <Sequence>
            <MoveBase goal="{goal}" />
        </Sequence>
    </BehaviorTree>
</root>