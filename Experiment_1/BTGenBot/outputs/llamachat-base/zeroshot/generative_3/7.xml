<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationC, StationD in sequence -->
            <SubTree ID="VisitStations" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="VisitStations">
        <Fallback>
            <!-- If StationE cannot be reached -->
            <Sequence>
                <Action ID="MoveTo" goal="StationB" />
            </Sequence>
            <Sequence>
                <Action ID="MoveTo" goal="StationA" />
                <Action ID="MoveTo" goal="StationC" />
                <Action ID="MoveTo" goal="StationD" />
            </Sequence>
        </Fallback>
    </BehaviorTree>

    <TreeNodesModel>
        <Action ID="MoveTo">
            <input_port name="goal">SDK_action_goal</input_port>
        </Action>
    </TreeNodesModel>
</root>