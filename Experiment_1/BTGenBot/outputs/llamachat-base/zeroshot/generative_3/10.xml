<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationC, StationD in order -->
            <Sequence>
                <SubTree ID="VisitStations" />
            </Sequence>
            <SubTree ID="VisitStations" />
            <SubTree ID="VisitStations" />
            <SubTree ID="VisitStations" />
            <SubTree ID="VisitStations" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="VisitStations">
        <Fallback>
            <ForceFailure>
                <Sequence>
                    <Action ID="MoveTo" goal="StationE" />
                </Sequence>
            </ForceFailure>
            <Sequence>
                <Action ID="MoveTo" goal="StationA" />
                <Action ID="MoveTo" goal="StationC" />
                <Action ID="MoveTo" goal="StationD" />
            </Sequence>
        </Fallback>
    </BehaviorTree>

    <TreeNodesModel>
        <Action ID="MoveTo">
            <input_port name="goal"/>
        </Action>
    </TreeNodesModel>
</root>