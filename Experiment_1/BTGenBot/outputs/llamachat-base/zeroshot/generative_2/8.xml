<root main_tree_to_execute = "MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <SubTree ID="StationA" />
            <SubTree ID="StationB" />
            <SubTree ID="StationC" />
            <SubTree ID="StationD" />
        </Sequence>
    </BehaviorTree>
   <BehaviorTree ID="StationA">
       <Sequence>
           <inverter>
               <Condition ID="VisitAllStations" />
           </inverter>
           <Action ID="GoToStation" goal="StationA" />
       </Sequence>
   </BehaviorTree>
   <BehaviorTree ID="StationB">
       <Sequence>
           <inverter>
               <Condition ID="VisitAllStations" />
           </inverter>
           <Action ID="GoToStation" goal="StationB" />
       </Sequence>
   </BehaviorTree>
   <BehaviorTree ID="StationC">
       <Sequence>
           <inverter>
               <Condition ID="VisitAllStations" />
           </inverter>
           <Action ID="GoToStation" goal="StationC" />
       </Sequence>
   </BehaviorTree>
   <BehaviorTree ID="StationD">
       <Sequence>
           <inverter>
               <Condition ID="VisitAllStations" />
           </inverter>
           <Action ID="GoToStation" goal="StationD" />
       </Sequence>
   </BehaviorTree>
   <Action ID="GoToStation" action_name="MoveTo" target_pose="{goal}" />
</root>