<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationF, StationD in order -->
            <Fallback>
                <Sequence>
                    <GetFieldinputAction field_name="station_id" value="StationA" />
                </Sequence>
                <Sequence>
                    <GetFieldinputAction field_name="station_id" value="StationE" />
                </Sequence>
                <Sequence>
                    <GetFieldinputAction field_name="station_id" value="StationF" />
                </Sequence>
                <Sequence>
                    <GetFieldinputAction field_name="station_id" value="StationD" />
                </Sequence>
            </Fallback>
            <Sequence>
                <GetFieldinputAction action_name="MoveTo" field_name="target_pose" />
                <MoveTo action_name="MoveTo" target_pose="{target_pose}"/>
            </Sequence>
        </Sequence>
    </BehaviorTree>
</root>