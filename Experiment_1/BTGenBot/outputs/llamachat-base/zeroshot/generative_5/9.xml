<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationF, StationD in order -->
            <Fallback>
                <Sequence>
                    <GetPathToPosition action="MoveTo" target="StationA" />
                    <MoveTo action="MoveTo" target="StationA" />
                </Sequence>
                <Sequence>
                    <GetPathToPosition action="MoveTo" target="StationE" />
                    <MoveTo action="MoveTo" target="StationE" />
                </Sequence>
                <Sequence>
                    <GetPathToPosition action="MoveTo" target="StationF" />
                    <MoveTo action="MoveTo" target="StationF" />
                </Sequence>
                <Sequence>
                    <GetPathToPosition action="MoveTo" target="StationD" />
                    <MoveTo action="MoveTo" target="StationD" />
                </Sequence>
            </Fallback>
            <Sequence>
                <Fallback>
                    <Sequence>
                        <GetPathToPosition action="MoveTo" target="StationB" />
                        <MoveTo action="MoveTo" target="StationB" />
                    </Sequence>
                    <Sequence>
                        <GetPathToPosition action="MoveTo" target="StationA" />
                        <MoveTo action="MoveTo" target="StationA" />
                    </Sequence>
                    <Sequence>
                        <GetPathToPosition action="MoveTo" target="StationE" />
                        <MoveTo action="MoveTo" target="StationE" />
                    </Sequence>
                    <Sequence>
                        <GetPathToPosition action="MoveTo" target="StationF" />
                        <MoveTo action="MoveTo" target="StationF" />
                    </Sequence>
                    <Sequence>
                        <GetPathToPosition action="MoveTo" target="StationD" />
                        <MoveTo action="MoveTo" target="StationD" />
                    </Sequence>
                </Fallback>
            </Sequence>
        </Sequence>
    </BehaviorTree>
    <TreeNodesModel>
        <Action ID="MoveTo">
            <input_port name="action"/>
            <input_port name="target"/>
        </Action>
    </TreeNodesModel>
</root>