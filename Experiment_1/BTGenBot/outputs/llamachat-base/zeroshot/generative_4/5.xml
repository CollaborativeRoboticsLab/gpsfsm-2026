<root main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Sequence>
           ; Visit Stations in sequence
            <SubTree ID="StationA" />
            <SubTree ID="StationE" condition="NoNodeAvailable" />
            <SubTree ID="StationF" condition="NoNodeAvailable" />
            <SubTree ID="StationD" />
            <SubTree ID="StationB" condition="StationE not reached" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationA">
        <Sequence>
            <Action ID="MoveTo" goal="StationA" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationB">
        <Sequence>
            <Action ID="MoveTo" goal="StationB" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationC">
        <Sequence>
            <Action ID="MoveTo" goal="StationC" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationD">
        <Sequence>
            <Action ID="MoveTo" goal="StationD" />
        </Sequence>
    </BehaviorTree>

    <BehaviorTree ID="StationE">
        <Fallback>
            <Sequence>
                <Action ID="MoveTo" goal="StationE" />
            </Sequence>
            <Sequence>
                <Action ID="MoveTo" goal="StationB" />
            </Sequence>
        </Fallback>
    </BehaviorTree>

    <BehaviorTree ID="StationF">
        <Sequence>
            <Action ID="MoveTo" goal="StationF" />
        </Sequence>
    </BehaviorTree>
</root>