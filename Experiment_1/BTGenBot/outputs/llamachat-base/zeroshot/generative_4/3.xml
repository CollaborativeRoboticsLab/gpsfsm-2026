<root main_tree_to_execute = "MainTree" >
    <BehaviorTree ID="MainTree">
        <Sequence>
            <SubTree ID="StationEAction" />
            <SubTree ID="StationFAction" />
            <SubTree ID="StationAAction" />
            <SubTree ID="StationDAction" />
        </Sequence>
    </BehaviorTree>
   <BehaviorTree ID="StationEAction">
        <Fallback>
            <Sequence>
                <Action ID="MoveTo" goal="StationE" />
            </Sequence>
            <Action ID="MoveTo" goal="StationB" />
        </Fallback>
   </BehaviorTree>
   <BehaviorTree ID="StationFAction">
        <Fallback>
            <Sequence>
                <Action ID="MoveTo" goal="StationF" />
            </Sequence>
            <Action ID="MoveTo" goal="StationC" />
        </Fallback>
   </BehaviorTree>
   <TreeNodesModel>
       <Action ID="MoveTo">
           <input_port name="goal"/>
       </Action>
   </TreeNodesModel>
</root>