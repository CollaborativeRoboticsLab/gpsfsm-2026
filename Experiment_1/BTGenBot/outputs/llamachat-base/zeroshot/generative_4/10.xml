<root main_tree_to_execute = "MainTree" >
    <BehaviorTree ID="MainTree">
        <Sequence>
            <!-- StationA, StationE, StationF, StationD in sequence -->
            <SubTree ID="StationA" />
            <SubTree ID="StationE" fallback="Nope" />
            <SubTree ID="StationF" />
            <SubTree ID="StationD" />
            
            <!-- If StationE is not reachable, move to StationB. If StationF is not reachable, move to StationC -->
            <Fallback name="StationE_Fallback">
                <SubTree ID="StationB" />
            </Fallback>
        </Sequence>
    </BehaviorTree>
 </root>